{
  "name": "sumbox",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "sumbox": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').cpSync('src/web/public','dist/web/public',{recursive:true})\"",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "migrate": "tsx src/db/migrate.ts up",
    "migrate:down": "tsx src/db/migrate.ts down",
    "migrate:create": "node-pg-migrate create -m src/db/migrations -j ts --migration-filename-format timestamp",
    "worker": "tsx src/workers/worker.ts",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "check": "biome check src",
    "eval:people-intent": "vitest run --config vitest.eval.config.ts"
  },
  "dependencies": {
    "@langfuse/client": "^5.9.1",
    "@langfuse/otel": "^5.9.1",
    "@langfuse/vercel-ai-sdk": "^5.9.1",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "ai": "^7.0.29",
    "amqplib": "^2.0.1",
    "commander": "^15.0.0",
    "dotenv": "^17.2.3",
    "ollama-ai-provider-v2": "^4.0.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "unzipper": "^0.12.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@testcontainers/postgresql": "^12.0.4",
    "@testcontainers/rabbitmq": "^12.0.4",
    "@types/amqplib": "^0.10.7",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.15.6",
    "@types/unzipper": "^0.10.11",
    "node-pg-migrate": "^8.0.4",
    "pino-pretty": "^13.0.0",
    "postcss": "^8.5.16",
    "qrcode-terminal": "^0.12.0",
    "testcontainers": "^12.0.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  }
}
